enum LeadStatus {
  NEW
  DELIVERED
  REFUNDED
  UNSOLD
  OPEN
  CLAIMED
  // New statuses for patient SMS qualification flow
  AWAITING_CONFIRM      // Sent confirm SMS, waiting for patient reply
  CONFIRMED             // Patient confirmed intent (replied 1)
  COLLECTING_DETAILS    // Collecting ZIP/time from patient
  QUALIFIED             // Patient fully qualified, ready for routing
  ROUTING               // Currently being routed to providers
  SCHEDULED             // Provider confirmed appointment
  COMPLETED             // Service completed
  NEEDS_COVERAGE        // No opted-in providers available
  CLOSED_UNCONFIRMED    // Patient didn't confirm (timed out)
  CLOSED_PRICING_ONLY   // Patient indicated pricing inquiry only
  CLOSED_DUPLICATE      // Older submission from a patient who re-submitted; canonical row is the most recent submission
  EXPIRED_NO_RESPONSE   // Lead aged out; providers WERE notified but none claimed within the window. Distinct from NEEDS_COVERAGE (which means no providers were available). Used by the unclaimed-lead recovery sweep to separate "providers ignored" from "no coverage existed."
}

enum LeadOutcome {
  CONTACTED
  // One-tap "I'm working it" engagement signal (2026-07-16). Set from the
  // dashboard so a provider working a lead offline can lock their claim without
  // logging a specific outcome yet — the stale-claim cron treats any non-null
  // outcome as engaged and skips it, so this stops the auto-release that was
  // confusing providers (Sherin/All Veins, Ponce). See project memory:
  // stale-claim offline-work friction. Overwritten when a real outcome is logged.
  WORKING_IT
  APPOINTMENT_BOOKED
  APPOINTMENT_COMPLETED
  NO_ANSWER
  VOICEMAIL
  // Added 2026-05-18 per Janelle Lashley feedback — mid-funnel outreach
  // signals so providers can document attempts without flipping to a
  // terminal state. Lead remains CLAIMED after these are set.
  TEXT_SENT
  EMAIL_SENT
  UNABLE_TO_REACH
  DECLINED
  WRONG_NUMBER
  DUPLICATE
  NOT_INTERESTED
  SCHEDULED_CALLBACK
  OUTSIDE_SERVICE_AREA
  NO_AVAILABILITY
  WRONG_SERVICE
  NO_ORDER
  // Added 2026-05-22 — completing the failed-contact sub-status set per
  // Janelle Lashley follow-up feedback. The full failed-contact cluster is
  // NO_ANSWER, VOICEMAIL, BUSY_OR_DISCONNECTED, WRONG_NUMBER,
  // INVALID_CONTACT_INFO, UNABLE_TO_REACH. lib/leadOutcomes.ts exports
  // FAILED_CONTACT_OUTCOMES so reporting can aggregate the whole cluster.
  //
  // Semantic distinction between the three "info problem" values:
  //   - UNABLE_TO_REACH      = tried; info was valid; no connect after
  //                            multiple attempts, no voicemail option.
  //   - BUSY_OR_DISCONNECTED = phone rang busy or line was out-of-service.
  //   - INVALID_CONTACT_INFO = contact data itself is broken (wrong format,
  //                            fake number, mismatched name/email).
  BUSY_OR_DISCONNECTED
  INVALID_CONTACT_INFO
  // Added 2026-05-26 after Aliya Simpson (AccuGen Diagnostics) reached out
  // saying the patient told her "I already found someone." Existing terminal
  // outcomes (DECLINED, NOT_INTERESTED) don't match — the patient didn't
  // decline service, they shopped multiple providers and picked another.
  // Distinct because (a) contact succeeded, so it's not failed-contact;
  // (b) patient still wanted the service, so it's not NOT_INTERESTED;
  // (c) it's a signal about competitive routing, not provider behavior.
  PATIENT_FOUND_OTHER
}

