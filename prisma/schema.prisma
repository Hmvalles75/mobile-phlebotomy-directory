generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Provider {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  phone                 String?
  phonePublic           String?
  email                 String?
  website               String?
  bookingUrl            String?
  description           String?
  rating                Float?
  reviewsCount          Int?
  featured              Boolean                @default(false)
  status                ProviderStatus         @default(UNVERIFIED)
  isFeatured            Boolean                @default(false)
  featuredTier          FeaturedTier?
  stripeCustomerId      String?
  claimEmail            String?
  claimToken            String?
  claimVerifiedAt       DateTime?
  twilioNumber          String?
  zipCodes              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  affiliateLink         String?
  isFeaturedCity        Boolean                @default(false)
  listingTier           ListingTier            @default(BASIC)
  serviceZipCodes       String?
  stripePaymentMethodId String?
  eligibleForLeads      Boolean                @default(false)
  trialExpiresAt        DateTime?
  trialStartedAt        DateTime?
  trialStatus           TrialStatus            @default(NONE)
  operatingDays         String?
  operatingHoursEnd     String?
  operatingHoursStart   String?
  serviceRadiusMiles    Int?
  logo                  String?
  profileImage          String?
  heroPoster            String?                // Optional wide poster image shown in premiumPage booking section (replaces the generic "Compassionate care" card when present)
  testimonials          String?                // JSON array of provider-supplied reviews: [{ quote, author, location, rating }]. Rendered in Patient Reviews section when present; section shows "Reviews coming soon" when null/empty.
  notificationEmail     String?
  notifyEnabled         Boolean                @default(true)
  primaryCity           String?
  primaryCitySlug       String?
  primaryMetro          String?
  primaryState          String?
  primaryStateName      String?
  primaryStateSlug      String?
  lastSMSSentAt         DateTime?
  smsOptInAt            DateTime?
  smsOptOutAt           DateTime?
  smsOptOutReason       String?
  // New fields for compliance-aware provider management
  source                ProviderSource         @default(SCRAPED)
  onboardingToken       String?                @unique
  onboardingStatus      OnboardingStatus       @default(NOT_INVITED)
  onboardingInvitedAt   DateTime?
  onboardingCompletedAt DateTime?
  termsAcceptedAt       DateTime?
  languages             String?                // Comma-separated: "English,Spanish"
  premiumPage           Boolean                @default(false)  // Renders premium $199 template
  // Set true by the junk-detection pass when the description looks like
  // scraped nav-menu junk (e.g. "HOME HOME CONTACT US BOOK ONLINE..."),
  // heavy ALL-CAPS, or repeated phrase patterns. Flagged providers render
  // "Contact for details." instead of the description on directory pages.
  // Surfaced in /admin/flagged-descriptions for cleanup. Reset to false
  // after the description is manually rewritten.
  descriptionFlagged    Boolean                @default(false)
  // Lead-routing priority flag — set true ONLY for providers who are actively paying
  // (any tier). Drives Wave 1 / Wave 2 split in lib/leadNotifications.ts so paying
  // customers get a real head-start window before free providers see leads in their
  // coverage area. Independent of featuredTier (which mixes paying + grandfathered)
  // and isFeatured (which has 20+ stale legacy entries). Set manually until the
  // Stripe webhook can write back reliably (see project memory: stripeCustomerId bug).
  priorityRouting       Boolean                @default(false)
  // ── Soft-removal at provider request ───────────────────────────────────────
  // removedAt: null = listing is live; timestamp = listing has been removed.
  // Listing queries in lib/providers-db.ts filter by removedAt:null so removed
  // rows disappear from city/state pages, search, and the provider detail page
  // (which then 404s, with optional 301 in next.config.mjs for canonical slugs).
  // We keep the row so Lead.routedToId history stays valid and the unique slug
  // blocks future scrapers from re-inserting under the same name.
  removedAt             DateTime?
  removedReason         String?                // free-text: "provider request", future "for cause", etc.
  // doNotRelist: hard-stop for future seeders/scrapers. Any script that creates
  // providers should refuse to insert when a matching (name + phone) row exists
  // with doNotRelist=true.
  doNotRelist           Boolean                @default(false)
  // Stale-claim tracking. Incremented when the stale-claim-release cron
  // yanks a CLAIMED lead from this provider for failing to log an outcome
  // within SLA. Surfaces in admin to spot patterns; high counts can feed
  // into auto-pause logic in future iterations of the pause-non-converter
  // workflow. lastStaleReleaseAt enables cooldown / "third strike" timing.
  staleReleaseCount     Int                    @default(0)
  lastStaleReleaseAt    DateTime?
  // Relations
  callLogs              CallLog[]
  leadNotifications     LeadNotification[]
  leads                 Lead[]
  address               ProviderAddress?
  availability          ProviderAvailability[]
  badges                ProviderBadge[]
  coords                ProviderCoords?
  businessClaims        BusinessClaim[]
  corrections           ProviderCorrection[]
  correctionsQueue      ProviderCorrections[]  @relation("corrections_queue")
  coverage              ProviderCoverage[]
  payment               ProviderPayment[]
  services              ProviderService[]
  institutionalOrders   InstitutionalOrder[]

  @@index([primaryState])
  @@index([primaryCity])
  @@index([primaryMetro])
  @@index([onboardingStatus])
  @@index([source])
  @@map("providers")
}

// ────────────────────────────────────────────────────────────────────
// B2B / Institutional client tracking. Replaces the spreadsheet workflow
// for clients like NeuroAge Therapeutics that send blood draw kits to
// patients across multiple states. Each order has a public share token
// the client can use (without auth) to see live status. Each client also
// has a single share token that surfaces all of their orders in one view.
// Privacy: public views only show patient first name + city/state, never
// the full address, contact info, pricing, or internal notes.
// ────────────────────────────────────────────────────────────────────
model InstitutionalClient {
  id               String   @id @default(cuid())
  name             String
  contactEmail     String
  ccEmails         String?  // comma-separated additional recipients
  notes            String?  @db.Text
  publicShareToken String   @unique @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           InstitutionalOrder[]
  users            ClientUser[]

  @@map("institutional_clients")
}

model InstitutionalOrder {
  id                 String   @id @default(cuid())
  clientId           String
  client             InstitutionalClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  patientName        String
  patientContactName String?  // primary contact if different from patient (e.g. caregiver)
  patientPhone       String
  patientEmail       String?
  patientAddress     String
  patientCity        String
  patientState       String
  patientZip         String
  patientNotes       String?  @db.Text

  protocolNotes      String?  @db.Text
  clientRate         Decimal  @db.Decimal(10, 2)

  assignedProviderId String?
  assignedProvider   Provider? @relation(fields: [assignedProviderId], references: [id])
  providerRate       Decimal? @db.Decimal(10, 2)

  kitShippedAt       DateTime?
  kitReceivedAt      DateTime?
  scheduledAt        DateTime?  // when scheduling was confirmed with patient
  scheduledFor       DateTime?  // actual appointment date/time
  drawCompletedAt    DateTime?
  fedexDroppedAt     DateTime?
  fedexTrackingNum   String?

  status             OrderStatus @default(PENDING_KIT_RECEIPT)
  publicShareToken   String   @unique @default(cuid())

  // Client-portal submission tracking (2026-07). submittedByClientUserId null =
  // admin-created; set = submitted by a client via the magic-link portal (WHO).
  // requestedWindow is the client's requested date/time window. submittedFromIp
  // is for audit (WHEN = createdAt). Client submissions land in PENDING_REVIEW.
  requestedWindow         String?
  submittedByClientUserId String?
  submittedByClientUser   ClientUser? @relation(fields: [submittedByClientUserId], references: [id], onDelete: SetNull)
  submittedFromIp         String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([clientId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([submittedByClientUserId])
  @@map("institutional_orders")
}

enum OrderStatus {
  // Client-submitted via the portal; awaiting admin review + rate. Deliberately
  // NOT part of the kit workflow until reviewed (2026-07).
  PENDING_REVIEW
  PENDING_KIT_SHIPMENT
  KIT_SHIPPED
  PENDING_KIT_RECEIPT
  KIT_RECEIVED
  PROVIDER_ASSIGNED
  SCHEDULED
  DRAW_COMPLETED
  FEDEX_DROPPED
  COMPLETED
  CANCELLED
}

// Client-portal user — per-person identity for magic-link auth. Admin-created
// only (you authorize who can log in). Disable (never hard-delete) to revoke,
// which preserves the submittedByClientUser audit link on their orders.
model ClientUser {
  id                String              @id @default(cuid())
  clientId          String
  client            InstitutionalClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email             String              @unique
  name              String?
  disabled          Boolean             @default(false)
  magicToken          String?           @unique
  magicTokenExpiresAt DateTime?
  lastLoginAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  submittedOrders   InstitutionalOrder[]

  @@index([clientId])
  @@map("client_users")
}

// Append-only auth/submission audit trail (who / when / IP) for the client
// portal — supports BAA/HIPAA audit expectations.
model ClientAuthEvent {
  id           String   @id @default(cuid())
  clientUserId String?
  email        String?
  event        String   // link_requested | link_verified | link_failed | order_submitted
  ip           String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([clientUserId])
  @@map("client_auth_events")
}

model Lead {
  id                String             @id @default(cuid())
  createdAt         DateTime           @default(now())
  fullName          String
  phone             String
  email             String?
  address1          String?
  city              String
  state             String
  zip               String
  urgency           Urgency
  notes             String?
  source            String
  gclid             String?
  routedToId        String?
  routedAt          DateTime?
  priceCents        Int
  status            LeadStatus         @default(NEW)
  labPreference     String             @default("Other/Unsure")
  claimedAt         DateTime?
  firstContactAt    DateTime?
  callAttempts      Int                @default(0)
  outcome           LeadOutcome?
  outcomeNotes      String?
  appointmentDate   DateTime?
  completedAt       DateTime?
  providerNotes     String?
  // New fields for patient SMS qualification flow
  timeWindow        String?            // e.g. "tomorrow 9-12"
  patientNotes      String?            // Notes from patient SMS
  confirmedAt       DateTime?          // When patient confirmed intent
  qualifiedAt       DateTime?          // When lead became fully qualified
  lastPatientSmsAt  DateTime?          // Track last SMS to patient
  patientSmsCount   Int                @default(0)
  routedProviderIds    String[]         // Array of providers we attempted to route to
  preferredProviderId  String?          // Provider the patient came from (e.g. clicked from provider page)
  // Attribution tracking (2026-04-22) — which page did this lead come from?
  attributionSource    String?          // Normalized: 'facebook' | 'google' | 'direct' | 'organic' | ...
  utmSource            String?          // Raw utm_source param
  utmMedium            String?          // Raw utm_medium param
  utmCampaign          String?          // Raw utm_campaign param
  referrer             String?          // document.referrer at submission time
  landingPage          String?          // First page they landed on in the session
  ipAddress            String?          // submitter IP (x-forwarded-for) — used for intake rate-limiting; mirrors CoverageRequest
  // Lead screening (2026-04-20, refined 2026-04-22) — routes unqualified leads out before they hit providers
  drawCount            String?          // "1-3" | "4-19" | "20+"
  requestType          String?          // "individual" | "organization" | "business" (legacy field, still captured)
  hasDoctorOrder       String?          // "yes" | "no" | "need_help"
  paymentMethod        String?          // "insurance" | "out_of_pocket" | "not_sure"
  isHighValue          Boolean          @default(false)  // drawCount = "20+" OR requestType in (organization, business)
  estimatedValueCents  Int              @default(0)      // draws × $75 (bucket midpoint × 7500)
  organizationName     String?
  timeframe            String?
  // SendGrid batch ID for the wave of notification emails sent for this lead.
  // Used to cancel scheduled (delayed) Wave 2/3 sends when the lead gets
  // claimed before they fire — see lib/cancelLeadNotifications.ts.
  notificationBatchId  String?
  // Set by the STAT-escalation cron the first time it alerts the admin
  // about a STAT lead sitting unclaimed past the threshold. Prevents
  // re-alerting on the same lead on every subsequent cron tick. Null on
  // STANDARD leads and on STAT leads that get claimed in time.
  statEscalatedAt      DateTime?
  // Stale-claim auto-release audit trail. Set when the cron auto-releases
  // a CLAIMED lead because the provider didn't log an outcome within the
  // SLA (STAT 2h, STANDARD 6h). Lead flips status back to OPEN and these
  // fields preserve who held it and why, so we can audit patterns and
  // exclude the original claimer from re-notification. See
  // lib/staleClaimRelease.ts and app/api/cron/stale-claim-release/route.ts.
  releasedFromProviderId String?
  releasedAt             DateTime?
  releaseReason          String?    // currently only "stale_claim"; future: "manual_admin", etc.
  // Number of times this lead has been auto-released by the stale-claim cron.
  // Guards the infinite claim->release->re-notify loop an unreachable patient
  // otherwise causes (Pasadena/Ken Yapkowitz 2026-07-09, 8 cycles of provider
  // spam). Once it reaches MAX_STALE_RELEASE_CYCLES the sweep expires the lead
  // terminally instead of re-notifying. See lib/staleClaimRelease.ts.
  staleReleaseCount      Int        @default(0)
  // Relations
  leadNotifications LeadNotification[]
  provider          Provider?          @relation(fields: [routedToId], references: [id])
  dispatchTasks     DispatchTask[]

  @@index([status])
  @@index([phone])
  @@index([isHighValue])
  @@map("leads")
}

/**
 * PhoneClickEvent — logs every click on a provider's click-to-call link.
 *
 * Captures INTENT (patient clicked to call), distinct from CallLog which
 * captures Twilio-tracked actual call completions. Provider-page views are
 * tracked in GA4; click events are tracked here so we can join intent with
 * downstream conversion in SQL rather than relying on external analytics.
 */
model PhoneClickEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  providerId String
  source     String   // e.g. 'provider_page_call' | 'featured_provider_call' | 'city_page_call' | 'state_page_call' | 'search_card_call'
  pagePath   String?  // window.location.pathname at click time
  userAgent  String?
  ipAddress  String?  // for rate-limit / bot filtering

  @@index([providerId])
  @@index([createdAt])
  @@index([source])
  @@map("phone_click_events")
}

model CallLog {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  fromNumber   String
  toNumber     String
  durationSec  Int?
  callStatus   String?
  city         String?
  state        String?
  zip          String?
  providerId   String?
  recordingUrl String?
  leadId       String?
  callSid      String?   @unique
  provider     Provider? @relation(fields: [providerId], references: [id])

  @@map("call_logs")
}

model CityNumber {
  id           String  @id @default(cuid())
  city         String
  state        String
  twilioNumber String  @unique
  providerId   String?

  @@map("city_numbers")
}

model Service {
  id        String            @id @default(cuid())
  name      String            @unique
  providers ProviderService[]

  @@map("services")
}

model ProviderService {
  id         String   @id @default(cuid())
  providerId String
  serviceId  String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id])

  @@unique([providerId, serviceId])
  @@map("provider_services")
}

model State {
  id       String             @id @default(cuid())
  name     String             @unique
  abbr     String             @unique
  cities   City[]
  coverage ProviderCoverage[]

  @@map("states")
}

model City {
  id       String             @id @default(cuid())
  name     String
  stateId  String
  slug     String
  state    State              @relation(fields: [stateId], references: [id])
  coverage ProviderCoverage[]

  @@unique([name, stateId])
  @@map("cities")
}

model ProviderCoverage {
  id         String   @id @default(cuid())
  providerId String
  stateId    String
  cityId     String?
  city       City?    @relation(fields: [cityId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  state      State    @relation(fields: [stateId], references: [id])

  @@unique([providerId, stateId, cityId])
  @@map("provider_coverage")
}

model ProviderAddress {
  id         String   @id @default(cuid())
  providerId String   @unique
  street     String?
  city       String?
  state      String?
  zip        String?
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_addresses")
}

model ProviderCoords {
  id         String   @id @default(cuid())
  providerId String   @unique
  lat        Float
  lng        Float
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_coords")
}

model Availability {
  id        String                 @id @default(cuid())
  name      String                 @unique
  providers ProviderAvailability[]

  @@map("availability")
}

model ProviderAvailability {
  id             String       @id @default(cuid())
  providerId     String
  availabilityId String
  availability   Availability @relation(fields: [availabilityId], references: [id])
  provider       Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, availabilityId])
  @@map("provider_availability")
}

model Payment {
  id        String            @id @default(cuid())
  name      String            @unique
  providers ProviderPayment[]

  @@map("payments")
}

model ProviderPayment {
  id         String   @id @default(cuid())
  providerId String
  paymentId  String
  payment    Payment  @relation(fields: [paymentId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, paymentId])
  @@map("provider_payments")
}

model Badge {
  id        String          @id @default(cuid())
  name      String          @unique
  providers ProviderBadge[]

  @@map("badges")
}

model ProviderBadge {
  id         String   @id @default(cuid())
  providerId String
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, badgeId])
  @@map("provider_badges")
}

model ProviderCorrection {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  providerId    String
  reporterName  String?
  reporterEmail String?
  issueType     String
  description   String
  status        CorrectionStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewNotes   String?
  provider      Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_corrections")
}

model ProviderCorrections {
  id           String                @id @default(cuid())
  providerId   String?
  urlSlug      String
  note         String
  contactEmail String?
  createdAt    DateTime              @default(now())
  handledAt    DateTime?
  handledBy    String?
  status       CorrectionQueueStatus @default(OPEN)
  provider     Provider?             @relation("corrections_queue", fields: [providerId], references: [id])

  @@map("provider_corrections_queue")
}

model BusinessClaim {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  status             BusinessClaimStatus @default(PENDING)
  providerId         String
  providerName       String
  claimantName       String
  claimantEmail      String
  claimantPhone      String
  requestedUpdates   String
  isOwnerConfirmed   Boolean            @default(false)
  verifiedAt         DateTime?
  verificationMethod String?
  verificationNotes  String?
  ipAddress          String?
  userAgent          String?
  provider           Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@map("business_claims")
}

enum BusinessClaimStatus {
  PENDING
  REGISTERED
  REJECTED
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  zipCode   String?
  source    String
  createdAt DateTime @default(now())
  notified  Boolean  @default(false)

  @@map("waitlist")
}

model PendingSubmission {
  id                 String           @id @default(cuid())
  submittedAt        DateTime         @default(now())
  status             SubmissionStatus @default(PENDING)
  businessName       String
  contactName        String
  email              String
  phone              String
  website            String?
  description        String
  address            String?
  city               String
  state              String
  zipCode            String?
  serviceArea        String?
  yearsExperience    String?
  licensed           Boolean          @default(false)
  insurance          Boolean          @default(false)
  certifications     String?
  specialties        String?
  emergencyAvailable Boolean          @default(false)
  weekendAvailable   Boolean          @default(false)
  logo               String?
  ipAddress          String?
  userAgent          String?
  leadOptIn          String?
  leadContactMethod  String?
  leadEmail          String?
  leadPhone          String?
  availability       String?
  // Attribution tracking
  attributionSource  String?          // Normalized source: 'facebook', 'google', 'direct', etc.
  utmSource          String?          // Raw utm_source param
  utmMedium          String?          // Raw utm_medium param
  utmCampaign        String?          // Raw utm_campaign param
  referrer           String?          // document.referrer value
  landingPage        String?          // First page they landed on
  // SMS consent capture (TCPA-compliant record of express written consent)
  smsConsent         Boolean   @default(false)
  smsConsentAt       DateTime?

  @@map("pending_submissions")
}

// B2B / institutional intake — labs, clinical-study sponsors, draw networks,
// SNF / healthcare facilities looking for ongoing coverage. Renamed from
// CorporateEventInquiry on 2026-05-08; existing 6 rows preserved through the
// migration (Medtronic, Elwyn, Lincoln Care Center, Symphony of Tri Cities,
// etc.). NOT auto-promoted to InstitutionalClient — admin manually qualifies
// before promotion to keep the real-client list clean.
model CoverageRequest {
  id               String                @id @default(cuid())
  createdAt        DateTime              @default(now())
  organizationName String
  contactName      String
  email            String
  phone            String?               // optional on the new /request-coverage form
  location         String                // free-text "where coverage is needed"
  statesNeeded     String?               // comma-separated states from the new lean form
  timeline         String?               // optional: when needed; captured in `details` on the lean form
  estimatedVolume  String                // dropdown bucket: "1–10/mo", "11–50/mo", "51–200/mo", "200+/mo", "Not sure yet"
  drawType         String                // "Clinical study/research", "Lab routing", "Healthcare facility", etc.
  details          String?
  status           CoverageRequestStatus @default(NEW)
  ipAddress        String?
  userAgent        String?
  // Attribution — where this prospect came from
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  referrer         String?
  landingPage      String?

  // Contact tracking (2026-07-17). Institutional outreach happens from Gmail,
  // outside the app, so status/staleness must key off logged activity rather
  // than createdAt. lastContactedAt is set whenever a ContactAttempt is logged,
  // an email is sent from admin, or the status is moved out of NEW.
  lastContactedAt  DateTime?
  contactAttempts  ContactAttempt[]

  @@map("coverage_requests")
}

enum ContactChannel {
  EMAIL
  PHONE
  OTHER
}

enum ContactDirection {
  OUTBOUND
  INBOUND
}

// Logged outreach against a CoverageRequest (institutional lead). One row per
// touch. `note` holds the email body when created by the admin "Email this
// lead" action, giving an audit trail. See app/api/admin/corporate-inquiries.
model ContactAttempt {
  id         String           @id @default(cuid())
  leadId     String
  lead       CoverageRequest  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel    ContactChannel   @default(EMAIL)
  direction  ContactDirection @default(OUTBOUND)
  subject    String?
  note       String?          @db.Text
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())

  @@index([leadId])
  @@map("contact_attempts")
}

model LeadNotification {
  id           String             @id @default(cuid())
  leadId       String
  providerId   String
  channel      String             @default("email")
  status       NotificationStatus @default(QUEUED)
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sentAt       DateTime?
  // SendGrid X-Message-Id from the API response (for correlating with EmailEvents)
  sgMessageId  String?
  // Times the retry-failed-notifications cron has re-attempted a FAILED send.
  // Capped at MAX_NOTIFICATION_RETRIES so a permanently-bad address doesn't
  // retry forever. See retryFailedNotifications() in lib/leadNotifications.ts.
  retryCount   Int                @default(0)
  lead         Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider     Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  emailEvents  EmailEvent[]

  @@index([leadId])
  @@index([providerId])
  @@index([sgMessageId])
  @@map("lead_notifications")
}

// SendGrid Event Webhook payload, stored per individual event.
// Source: https://docs.sendgrid.com/for-developers/tracking-events/event
// Linkage to our LeadNotification rows is via customArgs we attach when sending
// (leadNotificationId, leadId, providerId). Older sends without customArgs can
// still be matched best-effort via sgMessageId.
model EmailEvent {
  id                 String   @id @default(cuid())
  // sg_event_id is unique per event from SendGrid — used as idempotency key
  sgEventId          String   @unique
  // sg_message_id (the SG-internal message ID, not the X-Message-Id header)
  sgMessageId        String?
  event              String   // delivered, open, click, bounce, dropped, deferred, spamreport, unsubscribe, processed
  email              String   // recipient email
  timestamp          DateTime
  url                String?  // present on click events
  reason             String?  // present on bounce/dropped/spamreport
  ip                 String?
  userAgent          String?  @db.Text
  // Linkage via customArgs we attach to outbound sends
  leadNotificationId String?
  leadId             String?
  providerId         String?
  raw                String?  @db.Text // raw event JSON for debugging / future analysis
  createdAt          DateTime @default(now())
  leadNotification   LeadNotification? @relation(fields: [leadNotificationId], references: [id], onDelete: SetNull)

  @@index([leadNotificationId])
  @@index([leadId])
  @@index([providerId])
  @@index([sgMessageId])
  @@index([event])
  @@index([timestamp])
  @@map("email_events")
}

// Coverage gap task queue for admin follow-up
model DispatchTask {
  id          String             @id @default(cuid())
  leadId      String
  status      DispatchTaskStatus @default(OPEN)
  reason      DispatchTaskReason
  notes       String?
  assignedTo  String?            // Admin user ID or email
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  resolvedAt  DateTime?
  resolvedBy  String?
  lead        Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([leadId])
  @@map("dispatch_tasks")
}

// SMS event log for idempotency and audit trail
model SmsEvent {
  id          String   @id @default(cuid())
  twilioSid   String   @unique // Ensures idempotency
  direction   String   // INBOUND or OUTBOUND
  fromNumber  String
  toNumber    String
  body        String?
  status      String?  // Twilio status
  leadId      String?
  providerId  String?
  eventType   String   // e.g. PATIENT_CONFIRM, PROVIDER_CLAIM, etc.
  processed   Boolean  @default(false)
  processedAt DateTime?
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([fromNumber])
  @@index([toNumber])
  @@index([leadId])
  @@map("sms_events")
}

